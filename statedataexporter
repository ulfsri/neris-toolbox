    # Remove blank columns from both
    def clean_df(df):
        cols_to_drop = []
        for col in df.columns:
            vals = df[col].dropna()
            if vals.empty:
                cols_to_drop.append(col)
                continue
            if vals.apply(lambda x: x == '' or x == [] or (isinstance(x, str) and x == '[]')).all():
                cols_to_drop.append(col)
        return df.drop(columns=cols_to_drop)

